{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "command-route": {
        "ClusterId": "command-cluster",
        "Match": {
          "Path": "/command/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/command" }
        ]
      },
      "query-route": {
        "ClusterId": "query-cluster",
        "Match": {
          "Path": "/query/{**catch-all}"
        },
        "Transforms": [
          { "PathRemovePrefix": "/query" }
        ]
      }
    },
    "Clusters": {
      "command-cluster": {
        "Destinations": {
          "command": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "query-cluster": {
        "Destinations": {
          "query": {
            "Address": "http://localhost:5002/"
          }
        }
      }
    }
  }
}
